#!/bin/sh
# gen-hosts — turn an ndb host tree into a Typst registry.
#
# Reads every *.ndb under $BSH_NDB (default: ../examples/bsh-home/db/data) and
# emits a `#let hosts = (...)` dict to stdout. Each entry is keyed by every
# name-like attribute it carries (sys, dom, fqdn) so a route can cite any of
# them: `@university-base`, `@mkti-ps`, `@mkti.ps` all resolve to the same box.
# The value is the entry's whole attr bag (schema-less — ip may be absent).
#
#   ./gen-hosts > hosts.typ
#
# This is the bridge: `db.*` (the ndb browser) and the typeset layer share one
# source of truth. Regenerate whenever the ndb changes (a :w autocmd, a Make
# target, or by hand).
set -eu

ndbdir=${BSH_NDB:-"$(CDPATH= cd -- "$(dirname -- "$0")/../examples/bsh-home/db/data" && pwd)"}

printf '// generated by typst/gen-hosts from %s — do not edit by hand\n' "$ndbdir"
printf '#let hosts = (\n'

# One awk pass over all entries. ndb entry = a col-1 line plus indented
# continuations; blank / # lines separate or are ignored. We collect attrs,
# then on flush print a `"key": (a: "v", ...),` line for each name-like key.
awk '
  function esc(s){ gsub(/\\/, "\\\\", s); gsub(/"/, "\\\"", s); return s }
  function flush(   keys,nk,i,pairs,np,seen) {
    if (na == 0) return
    # build the attr dict literal once; a Typst dict cannot repeat a key, so on
    # an ndb multivalue attr (e.g. two `service=`) keep the first.
    pairs = ""; np = 0; delete seen
    for (i = 1; i <= na; i++) {
      if (ak[i] in seen) continue
      seen[ak[i]] = 1
      pairs = pairs (np++ ? ", " : "") ak[i] ": \"" esc(av[i]) "\""
    }
    # emit under each name-like key, deduped (sys often == dom)
    nk = 0; delete seen
    for (i = 1; i <= na; i++)
      if ((ak[i] == "sys" || ak[i] == "dom" || ak[i] == "fqdn") && !(av[i] in seen)) {
        seen[av[i]] = 1; keys[++nk] = av[i]
      }
    for (i = 1; i <= nk; i++)
      printf "  \"%s\": (%s),\n", esc(keys[i]), pairs
    na = 0; delete keys
  }
  /^[ \t]*#/ { next }
  /^[ \t]*$/ { flush(); next }
  {
    if ($0 ~ /^[^ \t]/) flush()          # new col-1 line starts a fresh entry
    for (i = 1; i <= NF; i++) {
      p = index($i, "=")
      if (p > 0) { na++; ak[na] = substr($i,1,p-1); av[na] = substr($i,p+1) }
    }
  }
  END { flush() }
' "$ndbdir"/*.ndb

printf ')\n'
